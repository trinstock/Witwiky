# Twitch Bot Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Twitch Application Credentials (Required)
# Get these from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# Bot Configuration (Required)
TWITCH_BOT_USERNAME=your_bot_username
TWITCH_CHANNEL_NAME=channel_you_want_to_join

# OAuth Configuration (Optional - for advanced features)
TWITCH_REDIRECT_URI=http://localhost:8080

# Bot Behavior Settings (Optional - has defaults)
COMMAND_PREFIX=!
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_DELAY=30
LOG_LEVEL=INFO

# Development Settings (Optional)
DEBUG=false